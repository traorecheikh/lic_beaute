{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "paths": {
      "@beauteavenue/contracts": ["./packages/contracts/dist/index.js"],
      "@beauteavenue/shared-ts": ["./packages/shared-ts/dist/index.js"]
    }
  }
}
