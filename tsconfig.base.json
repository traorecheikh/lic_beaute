{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@beauteavenue/contracts": ["packages/contracts/src/index.ts"],
      "@beauteavenue/shared-ts": ["packages/shared-ts/src/index.ts"]
    }
  }
}

