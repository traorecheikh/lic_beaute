API_PORT=3000
WEB_ORIGIN=http://localhost:5174
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/beaute_avenue?schema=public
SQLITE_DATABASE_PATH=./apps/api/.data/beauteavenue.dev.sqlite
DATABASE_CONNECT_RETRIES=3
DATABASE_CONNECT_RETRY_DELAY_MS=750
JWT_ACCESS_SECRET=dev-access-secret
JWT_REFRESH_SECRET=dev-refresh-secret
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000
EMAIL_DRIVER=noop
# EMAIL_DRIVER=smtp   → use Resend SMTP relay (recommended)
# EMAIL_DRIVER=resend → use Resend REST API
EMAIL_FROM=noreply@beauteavenue.sn
# Resend SMTP relay (EMAIL_DRIVER=smtp):
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=
# Resend REST API (EMAIL_DRIVER=resend):
RESEND_API_KEY=

OTP_DRIVER=noop
# OTP_DRIVER=africastalking
AT_API_KEY=
AT_USERNAME=

PUSH_DRIVER=noop
# PUSH_DRIVER=fcm
FCM_SERVICE_ACCOUNT_JSON_B64=
PAYMENT_DRIVER=intech
INTECH_API_KEY=your_intech_api_key
INTECH_API_SECRET=your_intech_api_secret
INTECH_ENV=test
INTECH_BASE_URL=https://api.intech.sn
INTECH_CALLBACK_HMAC_ENABLED=false
INTECH_HMAC_SECRET_KEY=
INTECH_HMAC_MAX_AGE_MS=300000
INTECH_REQUEST_TIMEOUT_MS=65000
STORAGE_DRIVER=r2
REDIS_URL=redis://localhost:6379
WORKER_DRIVER=hybrid
CACHE_ENABLED=true
CACHE_TTL_CATALOG_SECONDS=45
CACHE_TTL_KPI_SECONDS=20
QUEUE_CONCURRENCY_PAYMENTS=3
QUEUE_CONCURRENCY_NOTIFICATIONS=8
QUEUE_CONCURRENCY_MAINTENANCE=2
WORKER_POLL_INTERVAL_MS=5000
WORKER_BATCH_SIZE=25
PAYMENT_RECONCILE_MIN_INTERVAL_MS=15000
MAX_UPLOAD_BYTES=15728640

# Seed your OTP dev account with demo data (benefits + vouchers)
DEV_TEST_PHONE=
