# E2E Test credentials
# Copy this file to .e2e.env and fill in your test account details.
#
# The test account should be registered in the backend beforehand.
# For the "full flow" test, the account should have:
#   - No fullName set (so the profile bootstrap redirect fires)
#   - No payment methods (so the payment setup redirect fires)

E2E_EMAIL=e2e-test@beauteavenue.sn
E2E_PASSWORD=your-password-here
