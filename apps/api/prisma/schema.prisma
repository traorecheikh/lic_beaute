generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  client
  salon_staff
  salon_manager
  salon_owner
  platform_admin
}

enum SalonApprovalStatus {
  pending_review
  needs_info
  approved
  rejected
}

enum BookingStatus {
  pending
  confirmed
  in_progress
  completed
  cancelled
}

enum PaymentStatus {
  pending
  authorized
  succeeded
  failed
  refunded
}

enum SubscriptionTier {
  standard
  premium
}

enum SubscriptionStatus {
  inactive
  active
  past_due
  cancelled
  expired
  paused
}

enum PaymentProvider {
  paydunya
  manual
}

enum BlockedSlotScope {
  salon
  employee
}

enum SubscriptionChargeType {
  activate
  upgrade
  renewal
  downgrade
}

enum MediaOwnerType {
  salon
  user
}

enum PushPlatform {
  ios
  android
}

enum SettlementEventType {
  held
  released
  refunded
  balance_collected
}

enum ClientContactChannel {
  phone
  sms
  whatsapp
}

enum ClientBenefitKind {
  membership
  package
}

enum ClientBenefitStatus {
  active
  paused
  expired
  exhausted
  cancelled
}

enum VoucherRedemptionStatus {
  active
  used
  expired
}

enum CancellationReason {
  too_expensive
  missing_features
  low_traffic
  technical_issues
  poor_support
  seasonal_closure
  switching_competitor
  business_closure
  payment_issues
  other
}

enum MediaPurpose {
  salon_cover
  salon_logo
  salon_gallery
  kyc_document
  avatar
}

enum MediaVisibility {
  incoming
  public
  private_kyc
  rejected
}

enum UploadStatus {
  pending_upload
  upload_confirmed
  review_pending
  approved
  rejected
}

enum ReviewStatus {
  pending
  approved
  rejected
}

// ─── Core models ─────────────────────────────────────────────────────────────

model User {
  id                  String         @id @default(cuid())
  fullName            String
  email               String?        @unique
  phone               String?        @unique
  passwordHash        String?
  role                Role
  tokenVersion        Int            @default(0)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  salonId             String?
  salon               Salon?         @relation(fields: [salonId], references: [id], onDelete: SetNull)
  sessions            Session[]
  bookings            Booking[]
  notifications       Notification[]
  employees           Employee[]
  favorites           Favorite[]
  reviewsAsClient     Review[]       @relation("ReviewClient")
  reviewResponses     Review[]       @relation("ReviewResponder")
  pushTokens          PushToken[]
  bookingEvents       BookingEvent[]
  clientProfile       ClientProfile?
  paymentMethods      ClientPaymentMethod[]
  clientBenefits      ClientBenefit[]
  voucherRedemptions  ClientVoucherRedemption[]
  addresses           ClientAddress[]
  blockedSlotsCreated BlockedSlot[] @relation("BlockedSlotCreator")
  uploadedMedia       MediaAsset[]  @relation("UploadedMedia")
}

model Session {
  id            String   @id @default(cuid())
  userId        String
  refreshToken  String   @unique
  clientType    String
  userAgentHash String?
  expiresAt     DateTime
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, expiresAt])
}

model OtpChallenge {
  id             String   @id @default(cuid())
  phone          String   @unique
  codeHash       String
  expiresAt      DateTime
  failedAttempts Int      @default(0)
  createdAt      DateTime @default(now())
}

model EmailOtpChallenge {
  id             String   @id @default(cuid())
  email          String   @unique
  codeHash       String
  expiresAt      DateTime
  failedAttempts Int      @default(0)
  createdAt      DateTime @default(now())
}

model Salon {
  id                     String              @id @default(cuid())
  name                   String
  category               String
  logoUrl                String?
  description            String
  city                   String
  neighborhood           String?
  address                String
  latitude               Float?
  longitude              Float?
  averageRating          Float               @default(0)
  subscriptionTier       SubscriptionTier    @default(standard)
  subscriptionIntentTier SubscriptionTier    @default(standard)
  approvalStatus         SalonApprovalStatus @default(pending_review)
  latestAdminNote        String?
  submittedAt            DateTime            @default(now())
  depositPercentDefault  Float?
  isVisibleInMarketplace Boolean             @default(false)
  canReceiveBookings     Boolean             @default(false)
  prestigeScore          Float?
  isPrestige             Boolean             @default(false)
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  staffMembers           User[]
  services               Service[]
  bookings               Booking[]
  subscription           Subscription?
  documents              SalonDocument[]
  gallery                SalonGalleryImage[]
  employees              Employee[]
  blockedSlots           BlockedSlot[]
  salonHours             SalonHours[]
  favorites              Favorite[]
  reviews                Review[]
  clientBenefits         ClientBenefit[]
  vouchers               VoucherDefinition[]
  mediaAssets            MediaAsset[]

  @@index([approvalStatus, isVisibleInMarketplace, subscriptionTier, averageRating])
  @@index([city, approvalStatus, isVisibleInMarketplace])
  @@index([isPrestige, prestigeScore])
}

model Service {
  id                  String              @id @default(cuid())
  salonId             String
  name                String
  category            String              @default("general")
  durationMinutes     Int
  priceXof            Int
  depositMode         String              @default("none")
  depositAmountXof    Int?
  depositPercent      Int?
  isActive            Boolean             @default(true)
  displayOrder        Int                 @default(0)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  salon               Salon               @relation(fields: [salonId], references: [id], onDelete: Cascade)
  bookings            Booking[]
  employeeSpecialties EmployeeSpecialty[]

  @@index([salonId, isActive])
}

model Booking {
  id                   String            @id @default(cuid())
  clientId             String
  salonId              String
  serviceId            String
  employeeId           String?
  startsAt             DateTime
  endsAt               DateTime
  status               BookingStatus     @default(pending)
  source               String            @default("marketplace")
  depositAmountXof     Int               @default(0)
  depositPaymentStatus PaymentStatus     @default(pending)
  paymentProvider      PaymentProvider?
  paymentReference     String?
  clientNote           String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  client               User              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  salon                Salon             @relation(fields: [salonId], references: [id], onDelete: Cascade)
  service              Service           @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  employee             Employee?         @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  payments             Payment[]
  bookingEvents        BookingEvent[]
  settlementEvents     SettlementEvent[]
  review               Review?

  @@index([salonId, createdAt])
  @@index([salonId, status, createdAt])
  @@index([clientId, startsAt])
  @@index([employeeId, startsAt])
  @@index([salonId, startsAt, endsAt])
}

model Payment {
  id               String            @id @default(cuid())
  bookingId        String
  provider         PaymentProvider   @default(paydunya)
  status           PaymentStatus     @default(pending)
  amountXof        Int
  providerTxId     String?
  idempotencyKey   String            @unique
  webhookSignature String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  booking          Booking           @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  settlementEvents SettlementEvent[]

  @@index([bookingId])
  @@index([status, createdAt])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  title     String
  body      String
  channel   String
  readAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

model Subscription {
  id              String               @id @default(cuid())
  salonId         String               @unique
  tier            SubscriptionTier     @default(standard)
  status          SubscriptionStatus   @default(inactive)
  billingProvider PaymentProvider?
  isComplimentary Boolean              @default(false)
  autoRenew       Boolean              @default(false)
  pendingTier         SubscriptionTier?
  cancelReason        CancellationReason?
  cancelAdditionalInfo String?
  cancelRequestedAt   DateTime?
  startedAt           DateTime             @default(now())
  renewedAt           DateTime?
  expiresAt         DateTime?
  gracePeriodEndsAt DateTime?
  createdAt         DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  salon           Salon                @relation(fields: [salonId], references: [id], onDelete: Cascade)
  events          SubscriptionEvent[]
  invoices        BillingInvoice[]
  charges         SubscriptionCharge[]
}

model SubscriptionEvent {
  id             String       @id @default(cuid())
  subscriptionId String
  eventType      String
  summary        String
  actorName      String
  source         String
  payloadPreview String?
  createdAt      DateTime     @default(now())
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
}

model BillingInvoice {
  id             String              @id @default(cuid())
  subscriptionId String
  invoiceNumber  String              @unique
  amountXof      Int                 @default(0)
  status         String              @default("issued")
  pdfUrl         String              @default("")
  createdAt      DateTime            @default(now())
  subscription   Subscription        @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  charge         SubscriptionCharge?
}

model AuditLog {
  id               String   @id @default(cuid())
  action           String
  summary          String
  entityType       String
  entityId         String
  actorName        String
  actorUserId      String?
  severity         String   @default("info")
  payloadJson      String   @default("{}")
  relatedLinksJson String   @default("[]")
  createdAt        DateTime @default(now())
}

model EmailAudit {
  id           String   @id @default(cuid())
  to           String
  subject      String
  driver       String
  status       String
  errorMessage String?
  createdAt    DateTime @default(now())
}

model SalonDocument {
  id      String  @id @default(cuid())
  salonId String
  label   String
  status  String  @default("missing")
  note    String?
  fileUrl String?
  salon   Salon   @relation(fields: [salonId], references: [id], onDelete: Cascade)
}

model SalonGalleryImage {
  id        String   @id @default(cuid())
  salonId   String
  url       String
  position  Int      @default(0)
  createdAt DateTime @default(now())
  salon     Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)
}

model Job {
  id          String    @id @default(cuid())
  queue       String
  type        String
  payloadJson String
  bookingId   String?
  status      String    @default("pending")
  attempts    Int       @default(0)
  runAfter    DateTime  @default(now())
  lockedAt    DateTime?
  lastError   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, runAfter])
  @@index([queue, status])
}

model PlatformSetting {
  id          String   @id @default(cuid())
  group       String
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}

model PlatformSalonCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
}

model PlatformRequiredDocument {
  id         String   @id @default(cuid())
  label      String   @unique
  slug       String   @unique
  type       String
  isRequired Boolean  @default(true)
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())
}

model PaydunyaMethod {
  code      String   @id
  country   String
  label     String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([country, enabled])
  @@index([enabled])
}

model ClientAddress {
  id        String   @id @default(cuid())
  userId    String
  label     String
  street    String?
  city      String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, label])
  @@map("client_addresses")
}

// ─── New models ───────────────────────────────────────────────────────────────

model SalonHours {
  id        String  @id @default(cuid())
  salonId   String
  dayOfWeek Int
  isOpen    Boolean @default(false)
  opensAt   String?
  closesAt  String?
  salon     Salon   @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@unique([salonId, dayOfWeek])
}

model Employee {
  id                String              @id @default(cuid())
  salonId           String
  userId            String
  displayName       String
  avatarUrl         String?
  description       String?
  isActive          Boolean             @default(true)
  schedulingEnabled Boolean             @default(true)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  salon             Salon               @relation(fields: [salonId], references: [id], onDelete: Cascade)
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  specialties       EmployeeSpecialty[]
  bookings          Booking[]
  blockedSlots      BlockedSlot[]

  @@unique([salonId, userId])
}

model EmployeeSpecialty {
  id         String   @id @default(cuid())
  employeeId String
  serviceId  String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  service    Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([employeeId, serviceId])
}

model BlockedSlot {
  id              String           @id @default(cuid())
  salonId         String
  employeeId      String?
  startsAt        DateTime
  endsAt          DateTime
  reason          String?
  scope           BlockedSlotScope @default(salon)
  createdByUserId String
  createdAt       DateTime         @default(now())
  salon           Salon            @relation(fields: [salonId], references: [id], onDelete: Cascade)
  employee        Employee?        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdBy       User             @relation("BlockedSlotCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  salonId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  salon     Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@unique([userId, salonId])
}

model Review {
  id               String   @id @default(cuid())
  bookingId        String   @unique
  salonId          String
  clientId         String
  rating           Int
  comment          String?
  responseText     String?
  responseByUserId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  booking          Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  salon            Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)
  client           User     @relation("ReviewClient", fields: [clientId], references: [id], onDelete: Cascade)
  responseBy       User?    @relation("ReviewResponder", fields: [responseByUserId], references: [id], onDelete: SetNull)
}

model PushToken {
  id         String       @id @default(cuid())
  userId     String
  platform   PushPlatform
  deviceId   String
  token      String       @unique
  role       String?
  appVersion String?
  lastSeenAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime     @default(now())
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SubscriptionCharge {
  id             String                 @id @default(cuid())
  subscriptionId String
  provider       PaymentProvider
  status         PaymentStatus          @default(pending)
  amountXof      Int
  providerTxId   String?
  idempotencyKey String                 @unique
  chargeType     SubscriptionChargeType
  invoiceId      String?                @unique
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  subscription   Subscription           @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  invoice        BillingInvoice?        @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
}

model BookingEvent {
  id          String   @id @default(cuid())
  bookingId   String
  actorUserId String?
  eventType   String
  fromStatus  String?
  toStatus    String?
  payloadJson String   @default("{}")
  createdAt   DateTime @default(now())
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  actor       User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
}

model MediaAsset {
  id               String          @id @default(cuid())
  ownerType        MediaOwnerType
  ownerId          String
  salonId          String?
  uploadedBy       String?
  objectKey        String          @unique
  finalObjectKey   String?
  publicUrl        String?
  bucket           String          @default("beauteavenu")
  originalFilename String?
  fileExt          String?
  mimeType         String
  sizeBytes        Int             @default(0)
  purpose          MediaPurpose?
  visibility       MediaVisibility @default(incoming)
  uploadStatus     UploadStatus    @default(pending_upload)
  reviewStatus     ReviewStatus    @default(pending)
  rejectionReason  String?
  reviewedBy       String?
  reviewedAt       DateTime?
  displayOrder     Int             @default(0)
  deletedAt        DateTime?
  createdAt        DateTime        @default(now())

  salon            Salon?          @relation(fields: [salonId], references: [id], onDelete: SetNull)
  uploader         User?           @relation("UploadedMedia", fields: [uploadedBy], references: [id], onDelete: SetNull)
}

model SettlementEvent {
  id                String              @id @default(cuid())
  bookingId         String
  paymentId         String?
  eventType         SettlementEventType
  amountXof         Int
  providerReference String?
  createdAt         DateTime            @default(now())
  booking           Booking             @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  payment           Payment?            @relation(fields: [paymentId], references: [id], onDelete: SetNull)
}

model ClientProfile {
  id                      String               @id @default(cuid())
  userId                  String               @unique
  city                    String?
  avatarMediaId           String?              @unique
  avatarUrl               String?
  preferredContactChannel ClientContactChannel @default(phone)
  pushOptIn               Boolean              @default(true)
  marketingOptIn          Boolean              @default(false)
  preferredLanguage       String               @default("fr")
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  user                    User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ClientPaymentMethod {
  id             String          @id @default(cuid())
  userId         String
  provider       PaymentProvider
  phoneNumber    String
  label          String?
  method         String?
  country        String?
  isDefault      Boolean         @default(false)
  lastUsedAt     DateTime?
  idempotencyKey String?         @unique
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, provider])
}

model ClientBenefit {
  id            String              @id @default(cuid())
  userId        String
  salonId       String
  kind          ClientBenefitKind
  name          String
  status        ClientBenefitStatus @default(active)
  remainingUses Int?
  expiresAt     DateTime?
  billingDate   DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  salon         Salon               @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model VoucherDefinition {
  id             String                  @id @default(cuid())
  salonId        String?
  code           String                  @unique
  title          String
  description    String?
  discountLabel  String
  expiresAt      DateTime?
  isActive       Boolean                 @default(true)
  maxRedemptions Int?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  salon          Salon?                  @relation(fields: [salonId], references: [id], onDelete: SetNull)
  redemptions    ClientVoucherRedemption[]
}

model ClientVoucherRedemption {
  id         String                  @id @default(cuid())
  userId     String
  voucherId  String
  status     VoucherRedemptionStatus @default(active)
  redeemedAt DateTime                @default(now())
  usedAt     DateTime?
  expiresAt  DateTime?
  createdAt  DateTime                @default(now())
  updatedAt  DateTime                @updatedAt
  user       User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  voucher    VoucherDefinition       @relation(fields: [voucherId], references: [id], onDelete: Cascade)

  @@unique([userId, voucherId])
  @@index([userId, status])
}
