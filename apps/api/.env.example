API_PORT=3000
WEB_ORIGIN=http://localhost:5174
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/beaute_avenue?schema=public
JWT_ACCESS_SECRET=dev-access-secret
JWT_REFRESH_SECRET=dev-refresh-secret
JWT_ACCESS_TTL_SECONDS=7200
JWT_REFRESH_TTL_SECONDS=2592000
# Driver email: `noop`
EMAIL_DRIVER=noop
# Driver OTP: `noop` | `at` (`africastalking`)
OTP_DRIVER=noop
# Requis si OTP_DRIVER = at
AT_API_KEY=
AT_USERNAME=
AT_SENDER_ID=
# Driver push: `fcm` (actif) | autre valeur = no-op
PUSH_DRIVER=fcm
# Driver paiement: `mock` | `paydunya`
PAYMENT_DRIVER=paydunya
PAYDUNYA_MASTER_KEY=
PAYDUNYA_PUBLIC_KEY=
PAYDUNYA_PRIVATE_KEY=
PAYDUNYA_TOKEN=
PAYDUNYA_ENV=sandbox
PAYDUNYA_BASE_URL=https://app.paydunya.com
# Driver stockage: `noop` | `local`
STORAGE_DRIVER=local
MEDIA_PUBLIC_BASE_URL=https://media.beauteavenu.com
# Requis si PUSH_DRIVER = fcm (JSON service account en base64)
FCM_SERVICE_ACCOUNT_JSON_B64=
WORKER_POLL_INTERVAL_MS=5000
WORKER_BATCH_SIZE=25
SUBSCRIPTION_GRACE_PERIOD_DAYS=3
SUBSCRIPTION_EXPIRY_ENABLED=true

# ── Compte Google Play / App Store reviewer ───────────────────────────────
# Permet au reviewer de l'app store de se connecter sans envoyer de vrai
# code OTP par email. Utile UNIQUEMENT pendant le cycle de review.
#
# Comment ça marche :
#   1. Au moment de soumettre l'app aux stores, déployez avec ces 3 vars :
#        PLAY_REVIEW_ENABLED=true
#        PLAY_REVIEW_EMAIL=reviewer+beauteavenue@exemple.com
#        PLAY_REVIEW_OTP=123456
#   2. Le reviewer ouvre l'app, saisit reviewer+beauteavenue@exemple.com
#      puis tape 123456 comme code OTP → le code est accepté sans vérif
#      côté serveur (pas d'envoi d'email, pas de challenge stocké).
#   3. Une fois la review passée, supprimez les 3 vars ou mettez
#      PLAY_REVIEW_ENABLED=false → le circuit normal reprend.
#
# Sécurité : PLAY_REVIEW_ENABLED est FALSE par défaut (changé en audit S2).
# Avant S2, la valeur par défaut était TRUE, ce qui signifiait que le code
# de contournement était actif sur n'importe quel déploiement qui oubliait
# de le désactiver — seul l'email/OTP manquait. Maintenant le défaut est
# sécurisé : il faut explicitement activer la fonctionnalité.
# PLAY_REVIEW_ENABLED=true
# PLAY_REVIEW_EMAIL=
# PLAY_REVIEW_OTP=
