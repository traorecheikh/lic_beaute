API_PORT=3000
WEB_ORIGIN=http://localhost:5174
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/beaute_avenue?schema=public
JWT_ACCESS_SECRET=dev-access-secret
JWT_REFRESH_SECRET=dev-refresh-secret
JWT_ACCESS_TTL_SECONDS=7200
JWT_REFRESH_TTL_SECONDS=2592000
# Driver email: `noop`
EMAIL_DRIVER=noop
# Driver OTP: `noop` | `at` (`africastalking`)
OTP_DRIVER=noop
# Requis si OTP_DRIVER = at
AT_API_KEY=
AT_USERNAME=
AT_SENDER_ID=
# Driver push: `fcm` (actif) | autre valeur = no-op
PUSH_DRIVER=fcm
# Driver paiement: `mock` | `paydunya`
PAYMENT_DRIVER=paydunya
PAYDUNYA_MASTER_KEY=
PAYDUNYA_PUBLIC_KEY=
PAYDUNYA_PRIVATE_KEY=
PAYDUNYA_TOKEN=
PAYDUNYA_ENV=sandbox
PAYDUNYA_BASE_URL=https://app.paydunya.com
# Driver stockage: `noop` | `local`
STORAGE_DRIVER=local
MEDIA_PUBLIC_BASE_URL=https://media.beauteavenu.com
# Requis si PUSH_DRIVER = fcm (JSON service account en base64)
FCM_SERVICE_ACCOUNT_JSON_B64=
WORKER_POLL_INTERVAL_MS=5000
WORKER_BATCH_SIZE=25
SUBSCRIPTION_GRACE_PERIOD_DAYS=3
SUBSCRIPTION_EXPIRY_ENABLED=true
