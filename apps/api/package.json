{
  "name": "@beauteavenue/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "predev": "pnpm prisma:generate && pnpm --filter @beauteavenue/contracts build && pnpm --filter @beauteavenue/shared-ts build",
    "prebuild": "pnpm prisma:generate && pnpm --filter @beauteavenue/contracts build && pnpm --filter @beauteavenue/shared-ts build",
    "prelint": "pnpm prisma:generate && pnpm --filter @beauteavenue/contracts build && pnpm --filter @beauteavenue/shared-ts build",
    "pretypecheck": "pnpm prisma:generate && pnpm --filter @beauteavenue/contracts build && pnpm --filter @beauteavenue/shared-ts build",
    "pretest": "pnpm prisma:generate && pnpm --filter @beauteavenue/contracts build && pnpm --filter @beauteavenue/shared-ts build",
    "dev": "tsx watch src/index.ts",
    "worker:dev": "tsx watch src/worker.ts",
    "build": "tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:security": "vitest run src/modules/auth/session-security.test.ts src/modules/media/media-tenant-isolation.test.ts src/modules/payments/payment-webhook-security.test.ts",
    "test:race": "vitest run src/modules/bookings/booking-race.test.ts src/modules/payments/payment-race.test.ts",
    "test:contract": "vitest run src/integration/openapi-contract-compat.test.ts",
    "test:integration": "RUN_DB_INTEGRATION=1 vitest run src/app.test.ts src/modules/notifications/notifications.test.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:seed": "prisma db seed",
    "repair:booking-deposits": "tsx prisma/repair-booking-deposit-payments.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@aws-sdk/s3-request-presigner": "^3.1045.0",
    "@beauteavenue/contracts": "workspace:*",
    "@beauteavenue/shared-ts": "workspace:*",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.4",
    "@fastify/static": "^9.1.3",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "argon2": "^0.44.0",
    "bullmq": "^5.61.2",
    "dayjs": "^1.11.20",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "fastify-type-provider-zod": "6.1.0",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.7",
    "p-retry": "^8.0.0",
    "pg": "^8.20.0",
    "pdf-lib": "^1.17.1",
    "prisma": "^7.8.0",
    "resend": "^6.12.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.2",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@typescript/native-preview": "7.0.0-dev.20260508.1",
    "@vitest/coverage-v8": "^4.1.5",
    "pino-pretty": "13.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
