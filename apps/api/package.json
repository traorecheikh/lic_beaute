{
  "name": "@beauteavenue/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "predev": "pnpm --filter @beauteavenue/contracts build && pnpm --filter @beauteavenue/shared-ts build",
    "prebuild": "pnpm --filter @beauteavenue/contracts build && pnpm --filter @beauteavenue/shared-ts build",
    "prelint": "pnpm --filter @beauteavenue/contracts build && pnpm --filter @beauteavenue/shared-ts build",
    "pretypecheck": "pnpm --filter @beauteavenue/contracts build && pnpm --filter @beauteavenue/shared-ts build",
    "pretest": "pnpm --filter @beauteavenue/contracts build && pnpm --filter @beauteavenue/shared-ts build",
    "dev": "tsx watch src/index.ts",
    "worker:dev": "tsx watch src/worker.ts",
    "build": "tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:seed": "prisma db seed"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@aws-sdk/s3-request-presigner": "^3.1045.0",
    "@beauteavenue/contracts": "workspace:*",
    "@beauteavenue/shared-ts": "workspace:*",
    "@fastify/cookie": "^10.0.1",
    "@fastify/cors": "^10.1.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.4",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@prisma/client": "^5.22.0",
    "argon2": "^0.44.0",
    "dayjs": "^1.11.20",
    "dotenv": "^16.6.1",
    "fastify": "^5.8.5",
    "fastify-type-provider-zod": "5.1.0",
    "jsonwebtoken": "^9.0.3",
    "p-retry": "^8.0.0",
    "pg": "^8.20.0",
    "zod": "^3.25.76"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.19.18",
    "@types/pg": "^8.20.0",
    "pino-pretty": "13.1.3",
    "prisma": "^5.22.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
