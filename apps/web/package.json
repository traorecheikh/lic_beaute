{
  "name": "@beauteavenue/web-admin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "pnpm --filter @beauteavenue/contracts build && pnpm --filter @beauteavenue/shared-ts build",
    "prebuild": "pnpm --filter @beauteavenue/contracts build && pnpm --filter @beauteavenue/shared-ts build",
    "prelint": "pnpm --filter @beauteavenue/contracts build && pnpm --filter @beauteavenue/shared-ts build",
    "pretypecheck": "pnpm --filter @beauteavenue/contracts build && pnpm --filter @beauteavenue/shared-ts build",
    "pretest": "pnpm --filter @beauteavenue/contracts build && pnpm --filter @beauteavenue/shared-ts build",
    "dev": "vite",
    "build": "vite build",
    "lint": "vue-tsc --noEmit",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:flow": "PW_HEADLESS=false PW_SLOWMO=300 playwright test tests/e2e/full-flow-admin-pro.spec.ts --headed --workers=1",
    "test:e2e:panel": "PW_HEADLESS=false PW_SLOWMO=200 playwright test tests/e2e/panel-routes-smoke.spec.ts --headed --workers=1",
    "test:e2e:subscription": "PW_HEADLESS=false PW_SLOWMO=300 playwright test tests/e2e/pro-subscription-checkout.spec.ts --headed --workers=1",
    "test:e2e:list": "playwright test --list",
    "openapi:generate": "openapi-generator-cli generate -i ../api/openapi/openapi.json -g typescript-fetch -o src/lib/generated --additional-properties=typescriptThreePlus=true,supportsES6=true,modelPropertyNaming=original,useSingleRequestParameter=true"
  },
  "dependencies": {
    "@beauteavenue/contracts": "workspace:*",
    "@beauteavenue/shared-ts": "workspace:*",
    "@heroicons/vue": "^2.2.0",
    "@tanstack/vue-query": "^5.100.9",
    "@vee-validate/zod": "^4.15.1",
    "@vueuse/core": "^14.3.0",
    "dayjs": "^1.11.20",
    "leaflet": "^1.9.4",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "4.7.1",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.13",
    "vue-router": "^5.0.6",
    "vue-sonner": "^2.0.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "^2.32.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.6.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.10",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.8"
  }
}
